{
  "name": "@libs/api",
  "version": "1.0.0",
  "description": "Provides a lightweight and reusable API service layer for handling application requests, responses, and business logic orchestration.",
  "keywords": [
    "@libs",
    "api"
  ],
  "license": "MIT",
  "author": "Jesús Ángel Rodríguez Martínez",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run start:clean && npm run start:build",
    "start:build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start:clean": "rimraf dist",
    "start:integration-test": "npm run start:test -- --testMatch '**/*.integration.test.ts'",
    "start:integration-test:coverage": "npm run start:test -- --coverage --testMatch '**/*.integration.test.ts'",
    "start:test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "start:test:coverage": "npm run start:test -- --coverage",
    "start:unit-test": "npm run start:test -- --testMatch '**/*.unit.test.ts'",
    "start:unit-test:coverage": "npm run start:test -- --coverage --testMatch '**/*.unit.test.ts'",
    "test": "npm run start:test"
  },
  "dependencies": {
    "@libs/core": "workspace:*",
    "@libs/logger": "workspace:*",
    "@libs/security": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-openapi": "^12.1.3",
    "express-openapi-validator": "^5.5.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/json-schema": "~7.0.15",
    "@types/node": "^24.0.1",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "jest": "^29.7.0",
    "openapi-types": "^12.1.3",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.3.4",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.8.3"
  }
}
